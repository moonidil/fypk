generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  profile             Profile?
  projects            Project[]
  canvasBlocks        CanvasBlock[]
  platformConnections PlatformConnection[]
  feedbackReceived    Feedback[]           @relation("FeedbackReceiver")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  bio         String?
  slug        String   @unique
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//visibility states for an individual project
enum Visibility {
  DRAFT
  PRIVATE
  PUBLIC
}

model Project {
  id           String          @id @default(cuid())
  userId       String
  title        String
  description  String?
  visibility   Visibility      @default(DRAFT)
  problem      String?
  approach     String?
  outcome      String?
  reflection   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  artefacts    Artefact[]
  tags         ProjectTag[]
  canvasBlocks CanvasBlock[]
  timeline     TimelineEntry[]
}

model Artefact {
  id        String   @id @default(cuid())
  projectId String
  type      String
  url       String?
  content   String?
  label     String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  projects ProjectTag[]
}

model ProjectTag {
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
}

model CanvasBlock {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  type      String
  x         Int
  y         Int
  width     Int      @default(1)
  height    Int      @default(1)
  content   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id])
}

model TimelineEntry {
  id        String   @id @default(cuid())
  projectId String
  label     String
  date      DateTime
  note      String?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Feedback {
  id         String   @id @default(cuid())
  receiverId String
  token      String   @unique @default(cuid())
  rating     Int?
  comment    String?
  createdAt  DateTime @default(now())
  receiver   User     @relation("FeedbackReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model PlatformConnection {
  id           String   @id @default(cuid())
  userId       String
  platform     String
  accessToken  String?
  refreshToken String?
  connectedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}